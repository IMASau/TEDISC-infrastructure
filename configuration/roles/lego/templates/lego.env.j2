# Rendered by Ansible — do not hand-edit.
# Loaded by /etc/systemd/system/lego.service as EnvironmentFile.

# --- lego config ---
LEGO_PATH={{ lego_path }}
LEGO_EMAIL={{ lego_email }}
LEGO_DNS_PROVIDER={{ lego_dns_provider }}
LEGO_DOMAINS={{ lego_domains | join(' ') }}
LEGO_RENEW_DAYS={{ lego_renew_days }}
LEGO_CERT_GROUP={{ lego_cert_group }}
LEGO_RELOAD_SERVICE={{ lego_reload_service }}

# --- OpenStack app credential (for lego's Designate DNS provider) ---
OS_AUTH_TYPE=v3applicationcredential
OS_AUTH_URL={{ lego_openstack_auth_url }}
OS_REGION_NAME={{ lego_openstack_region }}
OS_INTERFACE=public
OS_IDENTITY_API_VERSION=3
OS_APPLICATION_CREDENTIAL_ID={{ lookup('openstack_secret', lego_appcred_id_secret_name) }}
OS_APPLICATION_CREDENTIAL_SECRET={{ lookup('openstack_secret', lego_appcred_secret_secret_name) }}
