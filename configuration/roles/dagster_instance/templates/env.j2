{# Rendered from roles/dagster_instance/templates/env.j2.
   Do not hand-edit — changes will be overwritten on the next play run.
   Instance: {{ instance.name }} #}

# --- Multi-instance contract vars (see TEDISC-Dagster/MULTI-INSTANCE.md) ---
COMPOSE_PROJECT_NAME={{ instance.name }}
DAGSTER_PORT={{ instance.port }}
DOCKER_SOCK=/run/user/{{ dagster_user_uid }}/podman/podman.sock
WORK_DIR={{ dagster_instances_root }}/{{ instance.name }}
{% if instance.user_code_image is defined %}
USER_CODE_IMAGE={{ instance.user_code_image }}
{% endif %}
{% if instance.dagster_image is defined %}
DAGSTER_IMAGE={{ instance.dagster_image }}
{% endif %}
{% if instance.docker_network is defined %}
DOCKER_NETWORK={{ instance.docker_network }}
{% endif %}
{% if instance.deploy_mode is defined %}
DEPLOY_MODE={{ instance.deploy_mode }}
{% endif %}

# --- Non-secret application env ---
{% for k, v in (instance.env | default({})).items() %}
{{ k }}={{ v }}
{% endfor %}

# --- Secrets fetched from Barbican via the openstack_secret lookup plugin ---
{% for k, secret_name in (instance.secrets | default({})).items() %}
{{ k }}={{ lookup('openstack_secret', secret_name) }}
{% endfor %}
