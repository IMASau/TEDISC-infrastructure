# Rendered from roles/caddy/templates/openstack.env.j2 — do not hand-edit.
# Consumed by /usr/local/bin/caddy via EnvironmentFile= in the systemd
# drop-in. Only the caddy user should be able to read this file.
#
# Gophercloud (the OpenStack SDK the caddy-dns/designate provider is built
# on) picks these up automatically; no Caddyfile-side auth needed.

OS_AUTH_TYPE=v3applicationcredential
OS_AUTH_URL={{ caddy_openstack_auth_url }}
OS_REGION_NAME={{ caddy_openstack_region }}
OS_INTERFACE=public
OS_IDENTITY_API_VERSION=3
OS_APPLICATION_CREDENTIAL_ID={{ lookup('openstack_secret', caddy_appcred_id_secret_name) }}
OS_APPLICATION_CREDENTIAL_SECRET={{ lookup('openstack_secret', caddy_appcred_secret_secret_name) }}
