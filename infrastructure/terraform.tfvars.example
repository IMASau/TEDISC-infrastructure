# Copy to terraform.tfvars and edit.

# Authentication ------------------------------------------------------------
# Either set os_cloud to a clouds.yaml entry, or leave it empty and `source`
# your Nectar openrc.sh before running tofu.
# os_cloud = "openstack"

# Instance ------------------------------------------------------------------
instance_name = "tedisc-vm"
key_pair_name = "my-keypair" # must already exist in the project

# Sizing --------------------------------------------------------------------
# Pick a flavor by CPU/RAM...
vcpus  = 2
ram_mb = 8192
# ...or pin an exact flavor name (overrides vcpus/ram_mb):
# flavor_name = "m3.medium"

# Image ---------------------------------------------------------------------
image_name = "NeCTAR Ubuntu 22.04 LTS (Jammy) amd64"

# Networking ----------------------------------------------------------------
# The Nectar zone your allocation is in — used for both the router's external
# gateway and the FIP pool. See `openstack network list --external`.
external_network_name = "tasmania"
security_groups       = ["default"]
# Optional: override the private subnet range (default 192.168.100.0/24).
# subnet_cidr = "192.168.100.0/24"
# Pre-allocate the floating IP out-of-band so it survives destroy/recreate:
#   openstack floating ip create tasmania
# then pin the address here so it stays valid for external whitelists.
floating_ip_address = "203.0.113.5"
